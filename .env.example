# Copy this file to `.env` and fill in your real Kit Key.
# Get one at https://developers.circle.com/w3s/keys#kit-keys
# Format: KIT_KEY:<id>:<secret>
VITE_KIT_KEY=KIT_KEY:REPLACE_ME_ID:REPLACE_ME_SECRET

# Production-only: Cloudflare Worker URL for Circle API proxy (swap CORS fix).
# Leave blank in dev (Vite dev server proxies locally). See cloudflare-worker/README.md.
VITE_CIRCLE_PROXY_URL=
